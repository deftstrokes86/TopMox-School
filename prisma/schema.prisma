generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TUTOR
  PARENT
}

enum AssessmentStatus {
  PENDING_REVIEW
  SCHEDULED
  COMPLETED
  PLAN_RECOMMENDED
  CONVERTED
  DECLINED
}

enum LessonStatus {
  SCHEDULED
  COMPLETED
  MISSED
  RESCHEDULED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  AWAITING_VERIFICATION
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  BANK_TRANSFER
  CASH
  CARD
  PAYMENT_GATEWAY_PLACEHOLDER
}

enum EnrollmentStatus {
  PENDING_PAYMENT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum HomeworkStatus {
  ASSIGNED
  SUBMITTED
  REVIEWED
  OVERDUE
}

enum ReportStatus {
  DRAFT
  REVIEW
  PUBLISHED
}

enum SupportStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  CLOSED
}

enum TutorStatus {
  ACTIVE
  PAUSED
  INACTIVE
}

enum CommunicationLogType {
  CALL
  WHATSAPP
  EMAIL
  INTERNAL_NOTE
  PAYMENT_FOLLOW_UP
  ACADEMIC_FOLLOW_UP
}

enum ResourceStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PreferredContactMethod {
  EMAIL
  WHATSAPP
  PHONE
}

enum NotificationType {
  ASSESSMENT_SUBMITTED
  ASSESSMENT_SCHEDULED
  PLAN_RECOMMENDED
  PLAN_ACCEPTED
  PAYMENT_SUBMITTED
  PAYMENT_APPROVED
  PAYMENT_REJECTED
  ENROLLMENT_ACTIVATED
  TUTOR_ASSIGNED
  LESSON_SCHEDULED
  LESSON_RESCHEDULED
  LESSON_CANCELLED
  LESSON_COMPLETED
  HOMEWORK_ASSIGNED
  REPORT_PUBLISHED
  SUPPORT_UPDATED
}

enum ProgressStatus {
  NEEDS_ATTENTION
  IMPROVING
  ON_TRACK
  EXCELLENT
}

model User {
  id                       String             @id @default(cuid())
  email                    String             @unique
  name                     String
  passwordHash             String?
  role                     Role
  image                    String?
  emailVerified            DateTime?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  profile                  Profile?
  parentProfile            ParentProfile?
  tutorProfile             TutorProfile?
  notifications            Notification[]
  authoredResources        Resource[]         @relation("ResourceAuthor")
  createdCommunicationLogs CommunicationLog[] @relation("CommunicationLogCreatedBy")

  @@index([email])
  @@index([role])
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  phone     String?
  country   String?
  timezone  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ParentProfile {
  id                     String                 @id @default(cuid())
  userId                 String                 @unique
  whatsappNumber         String
  country                String
  timezone               String
  preferredContactMethod PreferredContactMethod @default(WHATSAPP)
  heardAboutTopMox       String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  user                   User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  students               StudentProfile[]
  assessmentRequests     AssessmentRequest[]
  enrollments            Enrollment[]
  payments               Payment[]
  progressReports        ProgressReport[]
  supportRequests        SupportRequest[]
  lessons                Lesson[]
  communicationLogs      CommunicationLog[]
}

model StudentProfile {
  id                    String              @id @default(cuid())
  parentId              String
  fullName              String
  age                   Int
  classYearGroup        String
  countryOfStudy        String
  curriculum            String
  mainAcademicChallenge String
  academicGoal          String?
  preferredLessonDays   String[]
  preferredLessonTime   String
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  parent                ParentProfile       @relation(fields: [parentId], references: [id], onDelete: Cascade)
  subjects              Subject[]           @relation("StudentSupportSubjects")
  assessmentRequests    AssessmentRequest[]
  enrollments           Enrollment[]
  lessons               Lesson[]
  homework              Homework[]
  progressReports       ProgressReport[]
  supportRequests       SupportRequest[]
  payments              Payment[]
  communicationLogs     CommunicationLog[]

  @@index([parentId])
}

model TutorProfile {
  id                  String       @id @default(cuid())
  userId              String       @unique
  phone               String?
  bio                 String?
  availabilityNotes   String?
  status              TutorStatus  @default(ACTIVE)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjects            Subject[]    @relation("TutorSubjects")
  assignedEnrollments Enrollment[] @relation("EnrollmentAssignedTutor")
  lessons             Lesson[]
  homework            Homework[]
  progressReports     ProgressReport[]
}

model Subject {
  id          String              @id @default(cuid())
  name        String
  slug        String              @unique
  description String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  tutors      TutorProfile[]      @relation("TutorSubjects")
  students    StudentProfile[]    @relation("StudentSupportSubjects")
  assessments AssessmentRequest[] @relation("AssessmentSubjects")
  lessons     Lesson[]
  reports     ProgressReport[]    @relation("ReportSubjects")
}

model TutoringPlan {
  id                 String              @id @default(cuid())
  name               String
  slug               String              @unique
  description        String
  monthlyPrice       Decimal             @db.Decimal(10, 2)
  currency           String
  sessionsPerWeek    Int
  bestFor            String
  features           String[]
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  assessmentOutcomes AssessmentOutcome[]
  enrollments        Enrollment[]
}

model AssessmentRequest {
  id                      String            @id @default(cuid())
  parentId                String
  studentId               String
  status                  AssessmentStatus  @default(PENDING_REVIEW)
  academicConcern         String
  preferredAssessmentDate DateTime?
  preferredAssessmentTime String?
  timezone                String
  notes                   String?
  scheduledAt             DateTime?
  meetingLink             String?
  internalNotes           String?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  parent                  ParentProfile     @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student                 StudentProfile    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjects                Subject[]         @relation("AssessmentSubjects")
  outcome                 AssessmentOutcome?
  supportRequests         SupportRequest[]
  communicationLogs       CommunicationLog[]

  @@index([parentId])
  @@index([studentId])
  @@index([status])
  @@index([createdAt])
}

model AssessmentOutcome {
  id                           String            @id @default(cuid())
  assessmentRequestId          String            @unique
  recommendedPlanId            String?
  academicLevelSummary         String
  strengths                    String
  weakAreas                    String
  recommendedSubjects          String[]
  recommendedWeeklyLessonCount Int
  parentFacingSummary          String
  internalAdminNotes           String
  createdAt                    DateTime          @default(now())
  updatedAt                    DateTime          @updatedAt
  assessmentRequest            AssessmentRequest @relation(fields: [assessmentRequestId], references: [id], onDelete: Cascade)
  recommendedPlan              TutoringPlan?     @relation(fields: [recommendedPlanId], references: [id], onDelete: SetNull)
}

model Enrollment {
  id              String           @id @default(cuid())
  parentId        String
  studentId       String
  tutoringPlanId  String
  assignedTutorId String?
  status          EnrollmentStatus @default(PENDING_PAYMENT)
  startDate       DateTime?
  endDate         DateTime?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  parent          ParentProfile    @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student         StudentProfile   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tutoringPlan    TutoringPlan     @relation(fields: [tutoringPlanId], references: [id])
  assignedTutor   TutorProfile?    @relation("EnrollmentAssignedTutor", fields: [assignedTutorId], references: [id], onDelete: SetNull)
  payments        Payment[]
  lessons         Lesson[]
  progressReports ProgressReport[]

  @@index([parentId])
  @@index([studentId])
  @@index([assignedTutorId])
  @@index([status])
}

model Lesson {
  id                 String         @id @default(cuid())
  parentId           String
  studentId          String
  tutorId            String
  subjectId          String
  enrollmentId       String?
  title              String
  startTime          DateTime
  endTime            DateTime
  timezone           String
  meetingLink        String?
  status             LessonStatus   @default(SCHEDULED)
  attendanceMarkedAt DateTime?
  attended           Boolean?
  lessonNotes        String?
  concernFlag        Boolean?
  concernNote        String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  parent             ParentProfile  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student            StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tutor              TutorProfile   @relation(fields: [tutorId], references: [id])
  subject            Subject        @relation(fields: [subjectId], references: [id])
  enrollment         Enrollment?    @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  homework           Homework[]
  supportRequests    SupportRequest[]
  communicationLogs  CommunicationLog[]

  @@index([parentId])
  @@index([studentId])
  @@index([tutorId])
  @@index([subjectId])
  @@index([status])
  @@index([startTime])
}

model Homework {
  id          String         @id @default(cuid())
  studentId   String
  tutorId     String
  lessonId    String?
  title       String
  description String
  dueDate     DateTime?
  status      HomeworkStatus @default(ASSIGNED)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  student     StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tutor       TutorProfile   @relation(fields: [tutorId], references: [id])
  lesson      Lesson?        @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  @@index([studentId])
  @@index([tutorId])
  @@index([lessonId])
  @@index([status])
  @@index([dueDate])
}

model Payment {
  id             String        @id @default(cuid())
  parentId       String
  studentId      String?
  enrollmentId   String?
  amount         Decimal       @db.Decimal(10, 2)
  currency       String
  status         PaymentStatus @default(PENDING)
  paymentMethod  PaymentMethod
  reference      String?
  proofUrl       String?
  adminNote      String?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  parent         ParentProfile @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student        StudentProfile? @relation(fields: [studentId], references: [id], onDelete: SetNull)
  enrollment     Enrollment?   @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  supportRequests SupportRequest[]
  communicationLogs CommunicationLog[]

  @@index([parentId])
  @@index([enrollmentId])
  @@index([status])
  @@index([createdAt])
}

model ProgressReport {
  id                       String         @id @default(cuid())
  parentId                 String
  studentId                String
  tutorId                  String
  enrollmentId             String?
  reportingMonth           DateTime
  subjectsCovered          String
  attendanceSummary        String
  strengths                String
  areasNeedingImprovement  String
  homeworkCompletion       String
  tutorComments            String
  recommendedNextSteps     String
  parentActionPoints       String
  overallProgressStatus    ProgressStatus
  status                   ReportStatus   @default(DRAFT)
  publishedAt              DateTime?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
  parent                   ParentProfile  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student                  StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tutor                    TutorProfile   @relation(fields: [tutorId], references: [id])
  enrollment               Enrollment?    @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  linkedSubjects           Subject[]      @relation("ReportSubjects")

  @@index([parentId])
  @@index([studentId])
  @@index([tutorId])
  @@index([status])
  @@index([reportingMonth])
}

model SupportRequest {
  id                  String            @id @default(cuid())
  parentId            String
  studentId           String?
  lessonId            String?
  paymentId           String?
  assessmentRequestId String?
  subject             String
  message             String
  adminReply          String?
  status              SupportStatus     @default(OPEN)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  parent              ParentProfile     @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student             StudentProfile?   @relation(fields: [studentId], references: [id], onDelete: SetNull)
  lesson              Lesson?           @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  payment             Payment?          @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  assessmentRequest   AssessmentRequest? @relation(fields: [assessmentRequestId], references: [id], onDelete: SetNull)
  communicationLogs   CommunicationLog[]

  @@index([parentId])
  @@index([studentId])
  @@index([status])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  href      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([readAt])
  @@index([createdAt])
}

model CommunicationLog {
  id                  String               @id @default(cuid())
  type                CommunicationLogType
  message             String
  parentId            String?
  studentId           String?
  assessmentRequestId String?
  lessonId            String?
  paymentId           String?
  supportRequestId    String?
  createdById         String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  parent              ParentProfile?       @relation(fields: [parentId], references: [id], onDelete: SetNull)
  student             StudentProfile?      @relation(fields: [studentId], references: [id], onDelete: SetNull)
  assessmentRequest   AssessmentRequest?   @relation(fields: [assessmentRequestId], references: [id], onDelete: SetNull)
  lesson              Lesson?              @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  payment             Payment?             @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  supportRequest      SupportRequest?      @relation(fields: [supportRequestId], references: [id], onDelete: SetNull)
  createdBy           User?                @relation("CommunicationLogCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([parentId])
  @@index([studentId])
  @@index([assessmentRequestId])
  @@index([lessonId])
  @@index([paymentId])
  @@index([supportRequestId])
  @@index([createdById])
  @@index([createdAt])
}

model Resource {
  id        String         @id @default(cuid())
  title     String
  slug      String         @unique
  excerpt   String
  content   String
  category  String
  status    ResourceStatus @default(DRAFT)
  authorId  String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  author    User?          @relation("ResourceAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([slug])
  @@index([status])
  @@index([category])
}
