# PostgreSQL database connection used by Prisma.
# Example format:
# postgresql://user:password@localhost:5432/topmox?schema=public
DATABASE_URL=""

# Canonical app URL used by NextAuth for callbacks and URL generation.
NEXTAUTH_URL=""

# Primary NextAuth session/JWT encryption secret.
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# NextAuth standard secret variable.
# Keep this the same value as AUTH_SECRET for consistency.
NEXTAUTH_SECRET=""

# Demo login flags used by local development/private staging demos only.
# NEXT_PUBLIC_DEMO_LOGIN_ENABLED controls button visibility.
# DEMO_LOGIN_ENABLED is the server-side enforcement flag and source of truth.
# Keep both false in production.
DEMO_LOGIN_ENABLED="false"
NEXT_PUBLIC_DEMO_LOGIN_ENABLED="false"
DEMO_USER_PASSWORD=""

# Public app URL used by payment callbacks and generated absolute links.
APP_BASE_URL=""

# Flutterwave live payment gateway configuration.
# Do not commit real keys. Payment methods available through Flutterwave can
# vary by country, currency, merchant KYC, and Flutterwave account settings.
FLUTTERWAVE_PUBLIC_KEY=""
FLUTTERWAVE_SECRET_KEY=""
FLUTTERWAVE_SECRET_HASH=""
FLUTTERWAVE_BASE_URL="https://api.flutterwave.com/v3"

# Feature flags for payment options.
NEXT_PUBLIC_FLUTTERWAVE_ENABLED="true"
NEXT_PUBLIC_MANUAL_PAYMENTS_ENABLED="true"
